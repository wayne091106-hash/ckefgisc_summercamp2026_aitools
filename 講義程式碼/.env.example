# 複製這個檔案，改檔名為 .env，選其中一組貼上、填入你自己的金鑰
# （其他兩組保持刪掉或註解，只留一組啟用）

# ---------- 選項 A：Google AI Studio ----------
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=貼上你的 Google AI Studio 金鑰
LLM_MODEL=gemma-4-31b-it

# ---------- 選項 B：Groq ----------
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=貼上你的 Groq 金鑰
# LLM_MODEL=qwen/qwen3.6-27b

# ---------- 選項 C：NVIDIA NIM ----------
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_API_KEY=貼上你的 NVIDIA 金鑰
# LLM_MODEL=stepfun-ai/step-3.7-flash

# ---------- 搜尋工具（三個選項共用）----------
TAVILY_API_KEY=貼上你的 Tavily 金鑰
WORKSPACE_DIR=workspace
